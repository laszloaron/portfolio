# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portfolio_db
# NOTE: hostname MUST be 'db' (the docker-compose service name)
DATABASE_URL=postgresql+asyncpg://portfolio:changeme@db:5432/portfolio_db

# ─── Backend / FastAPI ────────────────────────────────────────────────────────
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Portfolio

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
# Pl. smtp.gmail.com, ha Gmailt használsz
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Ide írd a bejelentkezési email címed (pl. az_en_cimem@gmail.com)
SMTP_USER=
# Ide írd az Alkalmazásjelszavad (App Password), amit a Google fiókodban hoztál létre
SMTP_PASSWORD=
# Ez fog megjelenni Feladóként az emailben (általában egyezik az SMTP_USER-rel)
SMTP_FROM_EMAIL=
# Erre az email címre fognak érkezni a portfólióból küldött üzenetek
CONTACT_EMAIL=
